# matrix-taskbot.rc — configuration for matrix-taskbot
# Copy to ~/.task/config/matrix-taskbot.rc and edit before first run.

# Matrix homeserver (use matrix.org or your own)
homeserver=https://matrix-client.matrix.org

# Bot's Matrix user ID (create a dedicated account for the bot)
bot_user=@task-bot:matrix.org

# Your Matrix user ID — bot will only respond to messages from these users
# Comma-separated for multiple users
allowed_users=@linuxcaffe:matrix.org

# Max lines of task output to send per reply (avoid flooding)
max_output=40

# Path to task binary (default: task)
task=task
